# Redis Cloud connection
# Get these from your Redis Cloud dashboard: Database > Connect
# REDIS_URL is the "Public endpoint" (host:port)
# REDIS_PASSWORD is the "Default user password"
# REDIS_USER is the username (default: "default")
REDIS_URL=redis-12345.c232.us-east-1-2.ec2.cloud.redislabs.com:12345
REDIS_USER=default
REDIS_PASSWORD=your-password-here
